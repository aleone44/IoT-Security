    {
        "id": "db44776e5cf72ce8",
        "type": "function",
        "z": "8ff2036cdacd5b80",
        "name": "function 1",
        "func": "// --- 1. CONFIGURAZIONE ---\n// INSERISCI QUI LA TUA \"IMPRONTA MASTER\" (Copia la stringa binaria estratta la prima volta dall'ESP32)\nconst masterPuf = \"\";\nconst secretKey = CryptoJS.enc.Utf8.parse(\"SuperSegreta1234\"); // La stessa chiave dell'ESP32\n\n// --- 2. RECUPERO DATI E DECIFRATURA AES-128 ---\nconst datiCifratiHex = msg.payload.dati_sicuri;\n\nif (!datiCifratiHex) {\n    msg.payload = { stato: \"❌ ERRORE: Nessun payload cifrato ricevuto\" };\n    msg.statusCode = 400;\n    return msg;\n}\n\ntry {\n    const cipherParams = CryptoJS.lib.CipherParams.create({\n        ciphertext: CryptoJS.enc.Hex.parse(datiCifratiHex)\n    });\n\n    const decrypted = CryptoJS.AES.decrypt(cipherParams, secretKey, {\n        mode: CryptoJS.mode.ECB,\n        padding: CryptoJS.pad.Pkcs7\n    });\n\n    // Trasformiamo i byte decifrati in testo leggibile e poi in JSON\n    const datiInChiaroStr = decrypted.toString(CryptoJS.enc.Utf8);\n    const payloadOriginale = JSON.parse(datiInChiaroStr);\n\n    // --- 3. LOGICA PUF E DISTANZA DI HAMMING ---\n    const incomingPuf = payloadOriginale.puf;\n    let minLen = Math.min(masterPuf.length, incomingPuf.length);\n    let distanza = 0;\n\n    for (let i = 0; i < minLen; i++) {\n        if (masterPuf[i] !== incomingPuf[i]) {\n            distanza++;\n        }\n    }\n\n    let percentuale = (distanza / minLen) * 100;\n\n    // --- 4. OUTPUT PER LA DASHBOARD ---\n    msg.payload = {\n        messaggio: payloadOriginale.messaggio,\n        distanza_hamming: percentuale.toFixed(2) + \"%\"\n    };\n\n    if (percentuale < 55.0) {\n        msg.payload.stato = \" ACCESSO CONSENTITO (Dispositivo Autentico. Errore: \" + percentuale.toFixed(2) + \"%)\";\n        msg.statusCode = 200; // Risposta OK all'ESP32\n    } else {\n        msg.payload.stato = \" ACCESSO NEGATO (Clone rilevato! Errore: \" + percentuale.toFixed(2) + \"%)\";\n        msg.payload.messaggio = \"DATI BLOCCATI\";\n        msg.statusCode = 401; // Risposta Non Autorizzato\n    }\n\n    return msg;\n\n}  catch (error) {\n    // STAMPIAMO L'ERRORE REALE NEL DEBUG PER CAPIRE COSA SUCCEDE\n    node.error(\"ERRORE DI DECIFRATURA: \" + error.message);\n\n    msg.payload = {\n        stato: \" ATTACCO RILEVATO\",\n        messaggio: \"SCONOSCIUTO\"\n    };\n    msg.statusCode = 403;\n    return msg;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
